{
  "name": "anytype-mcp",
  "keywords": [
    "anytype",
    "api",
    "mcp",
    "server"
  ],
  "version": "1.2.9",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:dev": "vitest watch",
    "build": "tsc -build && node scripts/build-cli.js",
    "dev": "tsx watch scripts/start-server.ts",
    "parse-openapi": "tsx scripts/parse-openapi.ts",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "anytype-mcp": "bin/cli.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "axios": "1.18.1",
    "form-data": "4.0.6",
    "mustache": "4.2.0",
    "node-fetch": "3.3.2",
    "openapi-client-axios": "7.9.0",
    "openapi-schema-validator": "12.1.3",
    "openapi-types": "12.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "@eslint/js": "10.0.1",
    "@types/json-schema": "7.0.15",
    "@types/mustache": "4.2.6",
    "@types/node": "26.1.0",
    "@types/which": "3.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "10.6.0",
    "esbuild": "0.28.1",
    "openai": "6.45.0",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "description": "Self-hosted Anytype MCP server (Docker + Streamable HTTP). Fork of anyproto/anytype-mcp.",
  "repository": {
    "type": "git",
    "url": "https://github.com/anyproto/anytype-mcp.git"
  },
  "author": "@anyproto"
}
