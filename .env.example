# ── Anytype local API ──────────────────────────────────────────────────
# The Anytype desktop app must be running on this machine.
# Create an API key in:  Anytype → Settings → API Keys → Create new
# (or run:  npx -y @anyproto/anytype-mcp get-key )
ANYTYPE_API_KEY=

# API version header. The default matches the current Anytype API.
ANYTYPE_VERSION=2025-11-08

# Where the Anytype API is reachable FROM INSIDE the container.
# macOS/Windows Docker Desktop: host.docker.internal -> the host machine.
ANYTYPE_API_BASE_URL=http://host.docker.internal:31009

# ── MCP server ─────────────────────────────────────────────────────────
# Optional shared bearer token the Claude connector must send. Leave empty for
# localhost-only use. Generate: openssl rand -hex 32
MCP_SHARED_TOKEN=

# Host port to expose the MCP endpoint on (http://localhost:PORT/mcp).
PORT=8769

# Compact API responses before sending them to the assistant (drops empty
# property values, discriminators, and nested type definitions from results).
# Saves context and follow-up tool calls. Set to false for raw API payloads.
ANYTYPE_MCP_SLIM_RESPONSES=true
